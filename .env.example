# ============================================================================
# kilo-cli-telegram — Environment configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# Telegram Bot Token — obtained from @BotFather on Telegram
# Create a bot at https://t.me/BotFather and paste the token here.
# REQUIRED. The bot will not start without this.
TELEGRAM_BOT_TOKEN=

# Kilo Code server URL — REST API and SSE endpoint for the local Kilo Code CLI.
# The bot connects here to create sessions, send prompts, and receive events.
# Default: http://127.0.0.1:4096
# Start Kilo Code with: kilo serve
KILO_SERVER_URL=http://127.0.0.1:4096

# Path to a custom Kilo Code configuration file.
# Optional. If omitted, Kilo Code uses its default configuration.
# KILO_CONFIG_PATH=./kilo-config.json

# Logging level — one of: trace, debug, info, warn, error, fatal
# Default: info
# Set to debug during development for verbose output including SSE events.
LOG_LEVEL=info
